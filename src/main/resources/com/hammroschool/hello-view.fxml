<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="720" prefWidth="920" style="-fx-background-color: linear-gradient(to bottom right, #f6f6f4, #ecebea); -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hammroschool.controller.AuthController">
    <fx:define>
        <ToggleGroup fx:id="roleToggleGroup" />
    </fx:define>

    <children>
        <HBox alignment="CENTER" prefHeight="590" prefWidth="820" spacing="0" style="-fx-background-color: white; -fx-background-radius: 22; -fx-border-radius: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.16), 30, 0.18, 0, 12);">
            <children>
                <VBox prefWidth="430" spacing="18" style="-fx-background-color: white; -fx-background-radius: 22 0 0 22; -fx-padding: 28 34 28 34;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
                                    <image>
                                        <Image url="@images/login-page/logo.png" />
                                    </image>
                                </ImageView>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #1f1f1f;" text="Hammro School" />
                            </children>
                        </HBox>

                        <VBox spacing="7">
                            <children>
                                <Label style="-fx-font-size: 30px; -fx-font-weight: 800; -fx-text-fill: #161616;" text="Login to your Portal" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;" text="Select your role and enter your credentials." />
                            </children>
                        </VBox>

                        <HBox spacing="10">
                            <children>
                                <ToggleButton fx:id="studentRoleButton" alignment="CENTER" contentDisplay="TOP" onAction="#selectRole" prefHeight="68" prefWidth="98" selected="true" style="-fx-background-color: #202020; -fx-background-radius: 12; -fx-border-color: #202020; -fx-border-radius: 12; -fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: white; -fx-padding: 8 10 8 10;" text="Student" toggleGroup="$roleToggleGroup" userData="STUDENT">
                                    <graphic>
                                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                            <image>
                                                <Image url="@images/login-page/person-icon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="teacherRoleButton" alignment="CENTER" contentDisplay="TOP" onAction="#selectRole" prefHeight="68" prefWidth="98" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e3e3e3; -fx-border-radius: 12; -fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #202020; -fx-padding: 8 10 8 10;" text="Teacher" toggleGroup="$roleToggleGroup" userData="TEACHER">
                                    <graphic>
                                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                            <image>
                                                <Image url="@images/login-page/teacher-icon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="adminRoleButton" alignment="CENTER" contentDisplay="TOP" onAction="#selectRole" prefHeight="68" prefWidth="98" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e3e3e3; -fx-border-radius: 12; -fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #202020; -fx-padding: 8 10 8 10;" text="Admin" toggleGroup="$roleToggleGroup" userData="ADMIN">
                                    <graphic>
                                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                            <image>
                                                <Image url="@images/login-page/admin-icon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>
                            </children>
                        </HBox>

                        <ChoiceBox fx:id="roleChoiceBox" managed="false" prefHeight="1" visible="false" />

                        <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-text-fill: #252525; -fx-font-weight: 600;" text="Username" />
                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f7f7f5; -fx-background-radius: 10; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-padding: 10 12 10 12;">
                                    <children>
                                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                            <image>
                                                <Image url="@images/login-page/username-person-icon.png" />
                                            </image>
                                        </ImageView>
                                        <TextField fx:id="usernameField" prefHeight="28" promptText="Enter your username" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 14px; -fx-text-fill: #202020;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="8">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-text-fill: #252525; -fx-font-weight: 600;" text="Password" />
                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f7f7f5; -fx-background-radius: 10; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-padding: 10 12 10 12;">
                                    <children>
                                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                            <image>
                                                <Image url="@images/login-page/password-icon.png" />
                                            </image>
                                        </ImageView>
                                        <PasswordField fx:id="passwordField" prefHeight="28" promptText="Enter your password" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 14px; -fx-text-fill: #202020;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Button maxWidth="1.7976931348623157E308" onAction="#handleLogin" prefHeight="44" style="-fx-background-color: #171717; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 700; -fx-padding: 0 16 0 16;" text="Login">
                            <graphic>
                                <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                    <image>
                                        <Image url="@images/login-page/login-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Label fx:id="statusLabel" alignment="CENTER" style="-fx-text-fill: #707070; -fx-font-size: 13px; -fx-padding: 4 0 0 0;" textAlignment="CENTER" wrapText="true" />
                    </children>
                </VBox>

                <StackPane prefWidth="390" style="-fx-background-color: linear-gradient(to bottom right, #f7f3ed, #eaf0ff); -fx-background-radius: 0 22 22 0; -fx-padding: 24;">
                    <children>
                        <ImageView fitHeight="330" fitWidth="330" preserveRatio="true">
                            <image>
                                <Image url="@images/login-page/hero-image.png" />
                            </image>
                        </ImageView>
                    </children>
                </StackPane>
            </children>
        </HBox>
    </children>
</StackPane>
