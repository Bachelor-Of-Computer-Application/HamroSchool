<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" stylesheets="@styles.css"
            style="-fx-background-color: #f5f5f4; -fx-font-family: 'Segoe UI';"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamroschool.controller.StudentDashboardController">

    <left>
        <VBox prefWidth="216.0"
              style="-fx-background-color: white; -fx-border-color: #e7e5e4; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="28.0" left="20.0" right="20.0" top="20.0" /></padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" preserveRatio="true">
                            <image><Image url="@assets/logo.png" /></image>
                        </ImageView>
                        <VBox spacing="1.0">
                            <children>
                                <Label style="-fx-text-fill: #111111; -fx-font-size: 14px; -fx-font-weight: 800;" text="Hammro School" />
                                <Label style="-fx-text-fill: #a8a29e; -fx-font-size: 11px;" text="Student Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator style="-fx-opacity: 0.5;">
                    <VBox.margin><Insets bottom="8.0" top="16.0" /></VBox.margin>
                </Separator>

                <VBox spacing="2.0">
                    <children>
                        <Button fx:id="navDashboardBtn" alignment="CENTER_LEFT" graphicTextGap="10.0"
                                onAction="#handleNavDashboard" prefHeight="38.0" maxWidth="Infinity"
                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 0 12 0 12; -fx-cursor: hand;"
                                text="Dashboard">
                            <graphic>
                                <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                    <image><Image url="@assets/student-portal/aside/dashboard.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="navGradesBtn" alignment="CENTER_LEFT" graphicTextGap="10.0"
                                onAction="#handleNavGrades" prefHeight="38.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #44403c; -fx-font-size: 13px; -fx-font-weight: 500; -fx-padding: 0 12 0 12; -fx-cursor: hand;"
                                text="Grades">
                            <graphic>
                                <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                    <image><Image url="@assets/student-portal/aside/grades.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="navAttendanceBtn" alignment="CENTER_LEFT" graphicTextGap="10.0"
                                onAction="#handleNavAttendance" prefHeight="38.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #44403c; -fx-font-size: 13px; -fx-font-weight: 500; -fx-padding: 0 12 0 12; -fx-cursor: hand;"
                                text="Attendance">
                            <graphic>
                                <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                    <image><Image url="@assets/student-portal/grades/lowestgrade.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="10.0"
                        onAction="#handleLogout" prefHeight="38.0" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #44403c; -fx-font-size: 13px; -fx-font-weight: 500; -fx-padding: 0 12 0 12; -fx-cursor: hand;"
                        text="Logout">
                    <graphic>
                        <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                            <image><Image url="@assets/student-portal/aside/logout.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="0" style="-fx-background-color: #f5f5f4;">
                    <children>

                        <!-- Top Header -->
                        <VBox style="-fx-background-color: white; -fx-border-color: #e7e5e4; -fx-border-width: 0 0 1 0; -fx-padding: 20 28 20 28;">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #111111;"
                                                       text="Dashboard" />
                                                <Label fx:id="welcomeSubLabel"
                                                       style="-fx-font-size: 13px; -fx-text-fill: #78716c;"
                                                       text="Overview of academic performance, attendance trends, and upcoming priorities." />
                                            </children>
                                        </VBox>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0"
                                              style="-fx-background-color: #f5f5f4; -fx-background-radius: 999; -fx-border-color: #e7e5e4; -fx-border-radius: 999; -fx-padding: 6 14 6 8;">
                                            <children>
                                                <Label fx:id="userInitialsLabel"
                                                       style="-fx-background-color: #111111; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;"
                                                       text="PO" />
                                                <VBox>
                                                    <children>
                                                        <Label fx:id="userNameLabel"
                                                               style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;"
                                                               text="Pokemon" />
                                                        <Label style="-fx-text-fill: #78716c; -fx-font-size: 10px;" text="Student" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Main Content Area -->
                        <VBox spacing="20.0" style="-fx-padding: 24 28 28 28;">
                            <children>

                                <!-- Top 3 Stats Cards -->
                                <HBox fx:id="statCardsBox" spacing="16.0">
                                    <children>
                                        <!-- Total Subjects Card -->
                                        <VBox HBox.hgrow="ALWAYS" spacing="10.0"
                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-text-fill: #78716c; -fx-font-size: 12px;" text="Total Subjects" />
                                                            </children>
                                                        </VBox>
                                                        <StackPane style="-fx-background-color: #f5f5f4; -fx-background-radius: 8; -fx-min-width: 34; -fx-min-height: 34; -fx-pref-width: 34; -fx-pref-height: 34;">
                                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                                                <image><Image url="@assets/student-portal/grades/gpa.png" /></image>
                                                            </ImageView>
                                                        </StackPane>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="statSubjectsLabel" style="-fx-text-fill: #111111; -fx-font-size: 32px; -fx-font-weight: 800;" text="8" />
                                            </children>
                                        </VBox>

                                        <!-- Attendance Rate Card -->
                                        <VBox HBox.hgrow="ALWAYS" spacing="10.0"
                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-text-fill: #78716c; -fx-font-size: 12px;" text="Overall" />
                                                                <Label style="-fx-text-fill: #78716c; -fx-font-size: 12px;" text="Attendance Rate" />
                                                            </children>
                                                        </VBox>
                                                        <StackPane style="-fx-background-color: #f0fdf4; -fx-background-radius: 8; -fx-min-width: 34; -fx-min-height: 34; -fx-pref-width: 34; -fx-pref-height: 34;">
                                                            <Label style="-fx-text-fill: #16a34a; -fx-font-size: 18px;" text="✓" />
                                                        </StackPane>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="statAttLabel" style="-fx-text-fill: #111111; -fx-font-size: 32px; -fx-font-weight: 800;" text="87%" />
                                            </children>
                                        </VBox>

                                        <!-- GPA Card -->
                                        <VBox HBox.hgrow="ALWAYS" spacing="10.0"
                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-text-fill: #78716c; -fx-font-size: 12px;" text="Overall Grade /" />
                                                                <Label style="-fx-text-fill: #78716c; -fx-font-size: 12px;" text="GPA" />
                                                            </children>
                                                        </VBox>
                                                        <StackPane style="-fx-background-color: #eff6ff; -fx-background-radius: 8; -fx-min-width: 34; -fx-min-height: 34; -fx-pref-width: 34; -fx-pref-height: 34;">
                                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                                                <image><Image url="@assets/student-portal/grades/highestgrade.png" /></image>
                                                            </ImageView>
                                                        </StackPane>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="statGradeLabel" style="-fx-text-fill: #111111; -fx-font-size: 32px; -fx-font-weight: 800;" text="3.8" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Student Details Card -->
                                <VBox spacing="14.0"
                                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Student Information" />
                                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #78716c;" text="Personal and academic details" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Student Details Grid -->
                                        <GridPane hgap="20.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="25.0" />
                                                <ColumnConstraints percentWidth="25.0" />
                                                <ColumnConstraints percentWidth="25.0" />
                                                <ColumnConstraints percentWidth="25.0" />
                                            </columnConstraints>

                                            <!-- Row 1 -->
                                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="STUDENT ID" />
                                                    <Label fx:id="detailStudentId" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="FULL NAME" />
                                                    <Label fx:id="detailFullName" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="GENDER" />
                                                    <Label fx:id="detailGender" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="DATE OF BIRTH" />
                                                    <Label fx:id="detailDob" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <!-- Row 2 -->
                                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="CLASS" />
                                                    <Label fx:id="detailClass" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="ROLL NUMBER" />
                                                    <Label fx:id="detailRollNo" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="PHONE" />
                                                    <Label fx:id="detailPhone" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="EMAIL" />
                                                    <Label fx:id="detailEmail" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <!-- Row 3 -->
                                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="ADDRESS" />
                                                    <Label fx:id="detailAddress" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="GUARDIAN NAME" />
                                                    <Label fx:id="detailGuardianName" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="4.0" GridPane.columnIndex="3" GridPane.rowIndex="2">
                                                <children>
                                                    <Label style="-fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600;" text="GUARDIAN PHONE" />
                                                    <Label fx:id="detailGuardianPhone" style="-fx-text-fill: #111111; -fx-font-size: 13px; -fx-font-weight: 700;" text="—" />
                                                </children>
                                            </VBox>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <!-- StackPane for Dashboard/Grades/Attendance Views -->
                                <StackPane VBox.vgrow="ALWAYS">
                                    <children>

                                        <!-- Dashboard Pane - Two Columns Layout -->
                                        <HBox fx:id="dashboardPane" spacing="16.0">
                                            <children>

                                                <!-- Left Column - Recent Grades -->
                                                <VBox HBox.hgrow="ALWAYS" spacing="14.0"
                                                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Recent Grades" />
                                                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #78716c;" text="Latest subject performance snapshot" />
                                                                    </children>
                                                                </VBox>
                                                                <Label style="-fx-background-color: #f5f5f4; -fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 6 14; -fx-background-radius: 999; -fx-border-color: #e7e5e4; -fx-border-radius: 999;" text="This Week" />
                                                            </children>
                                                        </HBox>

                                                        <VBox fx:id="recentGradesContainer" spacing="10.0">
                                                            <!-- Grade items will be added dynamically -->
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <!-- Right Column - Recent Attendance -->
                                                <VBox HBox.hgrow="ALWAYS" spacing="14.0"
                                                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Recent Attendance" />
                                                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #78716c;" text="Subject-wise status overview" />
                                                                    </children>
                                                                </VBox>
                                                                <Label fx:id="attTodayLabelDash" style="-fx-background-color: #f5f5f4; -fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 6 14; -fx-background-radius: 999; -fx-border-color: #e7e5e4; -fx-border-radius: 999;" text="Today" />
                                                            </children>
                                                        </HBox>

                                                        <VBox fx:id="recentAttendanceContainer" spacing="10.0">
                                                            <!-- Attendance items will be added dynamically -->
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                            </children>
                                        </HBox>

                                        <!-- Grades Pane (New Modern Design) -->
                                        <VBox fx:id="gradesPane" spacing="20.0" visible="false" managed="false">
                                            <children>
                                                <!-- Top Stats Cards -->
                                                <HBox spacing="14.0">
                                                    <children>
                                                        <!-- Overall GPA Card -->
                                                        <VBox HBox.hgrow="ALWAYS" spacing="12.0"
                                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: #78716c; -fx-font-size: 13px; -fx-font-weight: 600;" text="Overall GPA" HBox.hgrow="ALWAYS" />
                                                                        <StackPane style="-fx-background-color: #dcfce7; -fx-background-radius: 8; -fx-min-width: 32; -fx-min-height: 32;">
                                                                            <Label style="-fx-text-fill: #16a34a; -fx-font-size: 16px;" text="🏆" />
                                                                        </StackPane>
                                                                    </children>
                                                                </HBox>
                                                                <Label fx:id="gradeStatGPA" style="-fx-text-fill: #111111; -fx-font-size: 36px; -fx-font-weight: 800;" text="3.8" />
                                                            </children>
                                                        </VBox>

                                                        <!-- Total Subjects Card -->
                                                        <VBox HBox.hgrow="ALWAYS" spacing="12.0"
                                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: #78716c; -fx-font-size: 13px; -fx-font-weight: 600;" text="Total Subjects" HBox.hgrow="ALWAYS" />
                                                                        <StackPane style="-fx-background-color: #f5f5f4; -fx-background-radius: 8; -fx-min-width: 32; -fx-min-height: 32;">
                                                                            <Label style="-fx-text-fill: #111111; -fx-font-size: 16px;" text="📚" />
                                                                        </StackPane>
                                                                    </children>
                                                                </HBox>
                                                                <Label fx:id="gradeStatTotal" style="-fx-text-fill: #111111; -fx-font-size: 36px; -fx-font-weight: 800;" text="8" />
                                                            </children>
                                                        </VBox>

                                                        <!-- Highest Grade Card -->
                                                        <VBox HBox.hgrow="ALWAYS" spacing="12.0"
                                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: #78716c; -fx-font-size: 13px; -fx-font-weight: 600;" text="Highest Grade" HBox.hgrow="ALWAYS" />
                                                                        <StackPane style="-fx-background-color: #fff7ed; -fx-background-radius: 8; -fx-min-width: 32; -fx-min-height: 32;">
                                                                            <Label style="-fx-text-fill: #ea580c; -fx-font-size: 16px;" text="📈" />
                                                                        </StackPane>
                                                                    </children>
                                                                </HBox>
                                                                <Label fx:id="gradeStatHighest" style="-fx-text-fill: #111111; -fx-font-size: 36px; -fx-font-weight: 800;" text="A+" />
                                                            </children>
                                                        </VBox>

                                                        <!-- Subjects Improved Card -->
                                                        <VBox HBox.hgrow="ALWAYS" spacing="12.0"
