<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hamroschool.controller.AccountController">

    <left>
        <VBox prefWidth="216.0" spacing="18.0" style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="16.0" top="18.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image><Image url="@assets/logo.png" /></image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hamro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Admin Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0">
                    <children>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavDashboard" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Dashboard">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/dashboard-dark.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Accounts" textFill="RED">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/account-dark.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavClasses" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Classes">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/account.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavTeachers" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Teachers">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/teacher.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavStudents" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Students">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/student.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavSettings" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Settings">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image><Image url="@assets/admin/aside/setting.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleLogout" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Logout">
                    <graphic>
                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                            <image><Image url="@assets/admin/aside/logout.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
        </VBox>
    </left>

    <center>
        <StackPane>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="22.0" style="-fx-padding: 24 28 28 28; -fx-background-color: transparent;">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Accounts" />
                                        <Label style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;" text="Manage all registered accounts" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 16 8 12; -fx-cursor: hand;">
                                    <children>
                                        <ImageView fitHeight="15.0" fitWidth="15.0" preserveRatio="true">
                                            <image><Image url="@assets/admin/account/alerts.png" /></image>
                                        </ImageView>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #272727;" text="Alerts" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label fx:id="userInitialsLabel" style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;" text="AD" />
                                        <Label fx:id="userNameLabel" style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;" text="admin" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.14, 0, 4);" VBox.vgrow="ALWAYS">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="All Accounts" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="All registered users in the system" />
                                            </children>
                                        </VBox>

                                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 10;">
                                            <children>
                                                <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                                    <image><Image url="@assets/admin/account/search.png" /></image>
                                                </ImageView>
                                                <TextField fx:id="searchField" prefHeight="36.0" promptText="Search" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 13px; -fx-text-fill: #222222; -fx-prompt-text-fill: #a0a0a0;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <TableView fx:id="accountTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userColumn" prefWidth="200.0" text="User" />
                                        <TableColumn fx:id="usernameColumn" prefWidth="160.0" text="Username" />
                                        <TableColumn fx:id="roleColumn" prefWidth="130.0" text="Role" />
                                        <TableColumn fx:id="actionsColumn" prefWidth="90.0" text="Actions" />
                                    </columns>
                                </TableView>

                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Label fx:id="summaryLabel" style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Showing 0 of 0 accounts" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox spacing="8.0">
                                            <children>
                                                <Button fx:id="prevButton" onAction="#handlePrevPage" style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 12 8 12; -fx-cursor: hand;" text="Previous" />
                                                <Button fx:id="nextButton" onAction="#handleNextPage" style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 12 8 12; -fx-cursor: hand;" text="Next" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <!-- ══ PROFILE DETAIL MODAL ══ -->
        <StackPane fx:id="profileModalOverlay" visible="false" managed="false"
                   style="-fx-background-color: rgba(0,0,0,0.5);">
            <VBox spacing="0" prefWidth="500.0" maxWidth="500.0" maxHeight="740.0"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.25),32,0.12,0,8);">

                <!-- Fixed header -->
                <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 14 14 0 0; -fx-border-color: transparent transparent #eceae6 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 20 26 0 26;">
                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                        <Label fx:id="profileAvatarLabel"
                               style="-fx-background-color: #111111; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 800; -fx-background-radius: 999; -fx-min-width: 50; -fx-min-height: 50; -fx-pref-width: 50; -fx-pref-height: 50; -fx-alignment: center;" text="AD"/>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="profileNameLabel" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Full Name"/>
                            <Label fx:id="profileUsernameLabel" style="-fx-font-size: 13px; -fx-text-fill: #78716c;" text="@username"/>
                        </VBox>
                        <Button onAction="#handleCloseProfileModal"
                                style="-fx-background-color: transparent; -fx-text-fill: #78716c; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 0 4;" text="×"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT" style="-fx-padding: 12 0 16 0;">
                        <Label fx:id="profileRoleBadge"
                               style="-fx-background-color: #f5f5f4; -fx-text-fill: #111111; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 3 10; -fx-background-radius: 999;" text="Student"/>
                        <Label fx:id="profileIdLabel"
                               style="-fx-background-color: #f5f5f4; -fx-text-fill: #78716c; -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 3 10; -fx-background-radius: 999;" text="ID: —"/>
                    </HBox>
                </VBox>

                <!-- Scrollable body -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="12.0" style="-fx-padding: 18 26;">

                            <!-- Personal info card -->
                            <VBox spacing="10.0" style="-fx-background-color: #fafaf9; -fx-background-radius: 10; -fx-border-color: #eceae6; -fx-border-radius: 10; -fx-padding: 14;">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Personal Information"/>
                                <HBox spacing="10.0">
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Full Name"/>
                                        <Label fx:id="profileFullNameVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Gender"/>
                                        <Label fx:id="profileGenderVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="10.0">
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Date of Birth"/>
                                        <Label fx:id="profileDobVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Phone"/>
                                        <Label fx:id="profilePhoneVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                </HBox>
                                <VBox spacing="2.0">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Email"/>
                                    <Label fx:id="profileEmailVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                </VBox>
                            </VBox>

                            <!-- Student academic card -->
                            <VBox fx:id="profileStudentSection" spacing="10.0"
                                  style="-fx-background-color: #fafaf9; -fx-background-radius: 10; -fx-border-color: #eceae6; -fx-border-radius: 10; -fx-padding: 14;">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Academic Information"/>
                                <HBox spacing="10.0">
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Class"/>
                                        <Label fx:id="profileClassVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Roll Number"/>
                                        <Label fx:id="profileRollVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                </HBox>
                                <VBox spacing="2.0">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Guardian"/>
                                    <Label fx:id="profileGuardianVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                </VBox>
                            </VBox>

                            <!-- Teacher professional card -->
                            <VBox fx:id="profileTeacherSection" spacing="10.0" visible="false" managed="false"
                                  style="-fx-background-color: #fafaf9; -fx-background-radius: 10; -fx-border-color: #eceae6; -fx-border-radius: 10; -fx-padding: 14;">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Professional Information"/>
                                <HBox spacing="10.0">
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Subject"/>
                                        <Label fx:id="profileSubjectVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Qualification"/>
                                        <Label fx:id="profileQualVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                    </VBox>
                                </HBox>
                                <VBox spacing="2.0">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #a8a29e;" text="Employment Status"/>
                                    <Label fx:id="profileEmploymentVal" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #111111;" text="—"/>
                                </VBox>
                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Fixed footer -->
                <HBox spacing="10.0" alignment="CENTER_RIGHT"
                      style="-fx-padding: 12 26 16 26; -fx-border-color: #eceae6 transparent transparent transparent; -fx-border-width: 1 0 0 0; -fx-background-color: white; -fx-background-radius: 0 0 14 14;">
                    <Button onAction="#handleCloseProfileModal" prefHeight="36.0" prefWidth="80.0"
                            style="-fx-background-color: white; -fx-border-color: #eceae6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #44403c; -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;" text="Close"/>
                    <Button onAction="#handleProfileEdit" prefHeight="36.0" prefWidth="110.0"
                            style="-fx-background-color: white; -fx-border-color: #eceae6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #44403c; -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;" text="✏ Edit"/>
                    <Button onAction="#handleProfileDelete" prefHeight="36.0" prefWidth="90.0"
                            style="-fx-background-color: white; -fx-border-color: #fca5a5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;" text="🗑 Delete"/>
                </HBox>
            </VBox>
        </StackPane>

        <!-- ══ EDIT MODAL ══ -->
        <StackPane fx:id="editModalOverlay" visible="false" managed="false"
                   style="-fx-background-color: rgba(0,0,0,0.5);">
            <VBox prefWidth="620.0" maxWidth="620.0" maxHeight="820.0" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.25),32,0.12,0,8);">

                <!-- Fixed header -->
                <VBox spacing="6.0" style="-fx-padding: 24 30 16 30; -fx-border-color: transparent transparent #eceae6 transparent; -fx-border-width: 0 0 1 0;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="editModalTitle" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Edit Account"/>
                            <Label fx:id="editModalSubtitle" style="-fx-font-size: 13px; -fx-text-fill: #78716c;" text=""/>
                        </VBox>
                        <Button onAction="#handleCloseEditModal"
                                style="-fx-background-color: transparent; -fx-text-fill: #78716c; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 0 4;" text="×"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #78716c;" text="Username:"/>
                        <Label fx:id="editUsernameDisplay"
                               style="-fx-background-color: #f5f5f4; -fx-text-fill: #111111; -fx-font-size: 12px; -fx-font-weight: 700; -fx-padding: 3 10; -fx-background-radius: 6;" text="—"/>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #78716c;" text="Role:"/>
                        <Label fx:id="editRoleDisplay"
                               style="-fx-background-color: #f5f5f4; -fx-text-fill: #111111; -fx-font-size: 12px; -fx-font-weight: 700; -fx-padding: 3 10; -fx-background-radius: 6;" text="—"/>
                    </HBox>
                </VBox>

                <!-- Scrollable body -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="12.0" style="-fx-padding: 16 30;">

                            <!-- Change Password -->
                            <VBox spacing="10.0" style="-fx-background-color: #fafaf9; -fx-background-radius: 10; -fx-border-color: #eceae6; -fx-border-radius: 10; -fx-padding: 14;">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #111111;" text="Change Password"/>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #a8a29e;" text="Leave blank to keep the current password"/>
                                <HBox spacing="10.0">
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="New Password"/>
                                        <PasswordField fx:id="editNewPasswordField" prefHeight="34.0"
                                                       style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #eceae6; -fx-border-radius: 8; -fx-padding: 0 10; -fx-font-size: 12px;"/>
                                    </VBox>
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Confirm Password"/>
                                        <PasswordField fx:id="editConfirmPasswordField" prefHeight="34.0"
                                                       style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #eceae6; -fx-border-radius: 8; -fx-padding: 0 10; -fx-font-size: 12px;"/>
                                    </VBox>
                                </HBox>
