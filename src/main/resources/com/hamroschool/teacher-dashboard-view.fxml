<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" stylesheets="@styles.css"
            style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamroschool.controller.TeacherDashboardController">

    <!-- ═══ SIDEBAR ═══ -->
    <left>
        <VBox prefWidth="220.0" spacing="18.0"
              style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="24.0" left="20.0" right="16.0" top="18.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image><Image url="@assets/logo.png" /></image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hamro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Teacher Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <VBox spacing="8.0">
                    <children>
                        <Button fx:id="navDashboardBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavDashboard" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Dashboard">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navAttendanceBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavAttendance" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Attendance">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/student.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navMarkSheetBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavMarkSheet" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Mark Sheet">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/account.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navReportCardBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavReportCard" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Report Card">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard-dark.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navPerformanceBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavPerformance" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Performance">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard.png" /></image>
                            </ImageView></graphic>
                        </Button>
                    </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="12.0"
                        onAction="#handleLogout" prefHeight="40.0" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                        text="Logout">
                    <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                        <image><Image url="@assets/admin/aside/logout.png" /></image>
                    </ImageView></graphic>
                </Button>
            </children>
        </VBox>
    </left>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 24 28 28 28; -fx-background-color: transparent;">
                    <children>
                        <!-- Top bar -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="pageTitle" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Attendance" />
                                        <Label fx:id="pageSubtitle" style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;" text="Mark and manage attendance for your assigned subject only" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label fx:id="attDateLabel" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-font-weight: 600;" text="Today" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label fx:id="userInitialsLabel" style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;" text="TC" />
                                        <Label fx:id="userNameLabel" style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;" text="teacher" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <StackPane VBox.vgrow="ALWAYS">
                            <children>

                                <!-- ══════════════════════════════════════════
                                     DASHBOARD PANE
                                     ══════════════════════════════════════════ -->
                                <VBox fx:id="dashboardPane" spacing="16.0">
                                    <children>
                                        <!-- Personal Information Card -->
                                        <VBox spacing="14.0"
                                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Personal Information" />

                                                <!-- Personal Details Grid -->
                                                <GridPane hgap="20.0" vgap="16.0">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="50.0" />
                                                        <ColumnConstraints percentWidth="50.0" />
                                                    </columnConstraints>

                                                    <!-- Row 1: Full Name and Gender -->
                                                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Full Name" />
                                                            <Label fx:id="detailTeacherName" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>

                                                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Gender" />
                                                            <Label fx:id="detailTeacherGender" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>

                                                    <!-- Row 2: Phone and Email -->
                                                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Phone" />
                                                            <Label fx:id="detailTeacherPhone" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>

                                                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Email" />
                                                            <Label fx:id="detailTeacherEmail" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>
                                                </GridPane>
                                            </children>
                                        </VBox>

                                        <!-- Professional Information Card -->
                                        <VBox spacing="14.0"
                                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Professional Information" />

                                                <!-- Professional Details Grid -->
                                                <GridPane hgap="20.0" vgap="16.0">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="50.0" />
                                                        <ColumnConstraints percentWidth="50.0" />
                                                    </columnConstraints>

                                                    <!-- Row 1: Teacher ID and Assigned Subject -->
                                                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Teacher ID" />
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT" style="-fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;">
                                                                <children>
                                                                    <Label fx:id="detailTeacherId" style="-fx-text-fill: #888888; -fx-font-size: 13px;" text="TCH-0012" />
                                                                    <Region HBox.hgrow="ALWAYS" />
                                                                    <Label style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-style: italic;" text="Auto-generated" />
                                                                </children>
                                                            </HBox>
                                                        </children>
                                                    </VBox>

                                                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                        <children>
                                                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                                                <children>
                                                                    <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Assigned Subject" />
                                                                    <Label style="-fx-text-fill: #dc2626; -fx-font-size: 14px; -fx-font-weight: 700;" text="*" />
                                                                </children>
                                                            </HBox>
                                                            <Label fx:id="detailTeacherSubject" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>

                                                    <!-- Row 2: Qualification and Employment Status -->
                                                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Qualification" />
                                                            <Label fx:id="detailTeacherQualification" style="-fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 10 12; -fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e5e5e5; -fx-border-radius: 8;" text="—" />
                                                        </children>
                                                    </VBox>

                                                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                        <children>
                                                            <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 14px; -fx-font-weight: 700;" text="Employment Status" />
                                                            <HBox spacing="8.0" alignment="CENTER_LEFT" style="-fx-padding: 10 12; -fx-background-color: #e0f2fe; -fx-background-radius: 8; -fx-border-color: #bae6fd; -fx-border-radius: 8;">
                                                                <children>
                                                                    <Label style="-fx-text-fill: #0284c7; -fx-font-size: 16px;" text="✓" />
                                                                    <Label fx:id="detailTeacherEmployment" style="-fx-text-fill: #0369a1; -fx-font-size: 13px; -fx-font-weight: 700;" text="Full-time" />
                                                                </children>
                                                            </HBox>
                                                        </children>
                                                    </VBox>
                                                </GridPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- ══════════════════════════════════════════
                                     ATTENDANCE PANE
                                     ══════════════════════════════════════════ -->
                                <VBox fx:id="attendancePane" spacing="16.0" visible="false" managed="false">
                                    <children>
                                        <HBox spacing="14.0">
                                            <children>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Total Students" /><Label fx:id="attTotalLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Present" /><Label fx:id="attPresentLabel" style="-fx-text-fill: #f97316; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Absent" /><Label fx:id="attAbsentLabel" style="-fx-text-fill: #dc2626; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Late" /><Label fx:id="attLateLabel" style="-fx-text-fill: #555555; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" /></children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <VBox spacing="14.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                    <children>
                                                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Class 10 — Section A" />
                                                                <Label fx:id="attSubjectLabel" style="-fx-font-size: 12px; -fx-text-fill: #8a8a8a;" text="Assigned subject: — · Read-only context set by admin" />
                                                            </children>
                                                        </VBox>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 10;">
                                                            <TextField fx:id="attSearchField" prefHeight="34.0" prefWidth="180.0" promptText="Search student..."
                                                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 13px;" />
                                                        </HBox>
                                                        <Button fx:id="attMarkAllPresentBtn" prefHeight="36.0"
                                                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 16 0 16; -fx-cursor: hand;"
                                                                text="✓ Mark All Present" />
                                                    </children>
                                                </HBox>
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label fx:id="subjectTagLabel" style="-fx-background-color: #111111; -fx-text-fill: white; -fx-padding: 5 14 5 14; -fx-background-radius: 8; -fx-font-size: 12px; -fx-font-weight: 700;" text="Subject" />
                                                        <Label style="-fx-background-color: #f4f4f3; -fx-text-fill: #888888; -fx-padding: 5 14 5 14; -fx-background-radius: 8; -fx-font-size: 12px;" text="No subject switching available" />
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="attTable" VBox.vgrow="ALWAYS" prefHeight="360.0">
                                                    <columns>
                                                        <TableColumn fx:id="attColRoll"    prefWidth="60.0"  text="Roll" />
                                                        <TableColumn fx:id="attColStudent" prefWidth="240.0" text="Student" />
                                                        <TableColumn fx:id="attColPct"     prefWidth="120.0" text="Attendance %" />
                                                        <TableColumn fx:id="attColStatus"  prefWidth="300.0" text="Status" />
                                                        <TableColumn fx:id="attColFeedback" prefWidth="220.0" text="Feedback" />
                                                    </columns>
                                                </TableView>
                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Showing students" />
                                                        <Label fx:id="attStatusLabel" style="-fx-font-size: 13px; -fx-font-weight: 700;" text="" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="attSaveBtn" prefHeight="36.0"
                                                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 18 0 18; -fx-cursor: hand;"
                                                                text="💾 Save Attendance" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- ══════════════════════════════════════════
                                     MARK SHEET PANE
                                     ══════════════════════════════════════════ -->
                                <VBox fx:id="markSheetPane" spacing="16.0" visible="false" managed="false">
                                    <children>
                                        <HBox spacing="14.0">
                                            <children>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Total Students" /><Label fx:id="msStatStudentsLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Average Marks" /><Label fx:id="msStatAvgLabel" style="-fx-text-fill: #f97316; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                                    <children><Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Pass Rate" /><Label fx:id="msStatPassLabel" style="-fx-text-fill: #16a34a; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" /></children>
                                                </VBox>
                                                <VBox prefWidth="190.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
